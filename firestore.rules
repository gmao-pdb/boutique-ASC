rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Config : lisible par tous (le formulaire public en a besoin), modifiable par les connectés.
    match /config/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pré-inscriptions : tout le monde peut DÉPOSER (formulaire QR), seuls les connectés peuvent lire/supprimer.
    match /preinscriptions/{doc} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Tout le reste (joueurs, stock, inventaires) : réservé aux utilisateurs connectés.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
